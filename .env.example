# ─── Supabase (required for backend mode) ────────────────────────────────────
# Get these from: https://supabase.com/dashboard → project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI key is SERVER-SIDE ONLY — never put it in the client bundle.
# Set it in Supabase secrets:  supabase secrets set OPENAI_API_KEY=sk-...

# ─── Google Sign In ──────────────────────────────────────────────────────────
# Create OAuth 2.0 credentials at console.cloud.google.com → APIs & Services → Credentials
# Web client ID (required):
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# iOS client ID (required on iPhone; in Expo Go you can reuse the web client ID):
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# Android client ID (required on Android; can reuse web client ID in Expo Go):
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
# Enable Google provider in Supabase: Dashboard → Auth → Providers → Google

# ─── Email confirmation (Supabase Auth → URL Configuration) ─────────────────
# Add every redirect URL the app uses (run the app once and check Metro logs, or log
# getEmailAuthRedirectUrl() from src/auth/authRedirect.ts). Examples:
#   physiquemax://auth/callback
#   exp://127.0.0.1:8081/--/auth/callback          (Expo Go on simulator)
#   exp://192.168.x.x:8081/--/auth/callback       (Expo Go on device, LAN)
# Site URL can stay as your production web URL; redirect URLs must include the list above.
#
# Dev tip — avoid "email rate limit" while testing signups:
# Supabase Dashboard → Authentication → Providers → Email → disable "Confirm email".
# Or confirm users manually: Authentication → Users → user → Confirm email.

# ─── App Config ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=development

# Set to true to skip all network calls and use local mock data instead.
EXPO_PUBLIC_USE_MOCK_API=true
